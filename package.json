{
  "name": "reader-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run copy-pdf-worker && next dev",
    "build": "npm run copy-pdf-worker && next build",
    "start": "next start",
    "lint": "eslint",
    "copy-pdf-worker": "node -e \"const fs=require('fs');const p=require.resolve('pdfjs-dist/build/pdf.worker.mjs');fs.mkdirSync('public',{recursive:true});fs.copyFileSync(p,'public/pdf.worker.mjs');console.log('copied pdfjs worker →','public/pdf.worker.mjs');\""
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "jszip": "^3.10.1",
    "next": "16.2.2",
    "pdfjs-dist": "^4.8.69",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
